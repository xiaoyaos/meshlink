#!/usr/bin/expect -f
set timeout 30
set ip "8.136.129.162"
set user "root"
set pass "Hjj123456"

spawn ssh -o StrictHostKeyChecking=no $user@$ip
expect "password:"
send "$pass\r"
expect "# "

send "journalctl -u meshlink --since \"10 minutes ago\" --no-pager\r"
expect "# "

send "exit\r"
expect eof

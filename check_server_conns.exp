#!/usr/bin/expect -f
set timeout 30
set ip "8.136.129.162"
set user "root"
set pass "Hjj123456"

spawn ssh -o StrictHostKeyChecking=no $user@$ip
expect "password:"
send "$pass\r"
expect "# "

# Check peers from the running meshlink process via address file or something?
# No, p2p-node doesn't have a RPC port yet.
# We can use netstat to see established connections to 4001.
send "ss -tnp | grep :4001\r"
expect "# "

send "exit\r"
expect eof

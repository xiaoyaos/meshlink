#!/usr/bin/expect -f
set timeout 30
set ip "8.136.129.162"
set user "root"
set pass "Hjj123456"

spawn ssh -o StrictHostKeyChecking=no $user@$ip
expect "password:"
send "$pass\r"
expect "# "

puts "\n--- CHECKING SERVICE STATUS ---\n"
send "systemctl status meshlink\r"
expect "# "

puts "\n--- CHECKING LOGS ---\n"
send "journalctl -u meshlink -n 50 --no-pager\r"
expect "# "

puts "\n--- CHECKING LISTEN PORTS ---\n"
send "ss -tlnp | grep 4001\r"
expect "# "

send "exit\r"
expect eof

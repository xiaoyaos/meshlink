#!/usr/bin/expect -f
set timeout 60
set pass "Hjj123456"
set addr "/ip4/8.136.129.162/tcp/4001/p2p/12D3KooWLd56gZpYP2Q1hejJ2juN6GoYQcA9VMTcek6aetTRfwYi"
set server_vip "10.98.237.157"

# Start the client
spawn sudo ./dist/bin/p2p-node-darwin-arm64 -port 4002 -config ./config_mac1 -bootstrap $addr
expect {
    "Password:" {
        send "$pass\r"
    }
}

expect {
    "meshlink is running" {
        puts "\nCLIENT_READY\n"
    }
    timeout {
        puts "\nTIMEOUT_STARTING_CLIENT\n"
        exit 1
    }
}

# Wait for DHT and advertisement
sleep 15

# Try to ping the server VIP
puts "\nSTARTING_PING_TEST\n"
spawn ping -c 4 $server_vip
expect {
    "4 packets transmitted, 4 packets received" {
        puts "\nPING_SUCCESS\n"
    }
    timeout {
        puts "\nPING_TIMEOUT\n"
    }
}

# Cleanup
exec sudo pkill p2p-node
expect eof
